{
  "name": "smartdoor-server",
  "version": "2.0.0",
  "description": "Smart Door backend — TypeScript rewrite",
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc && npx prisma generate",
    "start": "node dist/index.js",
    "contract:prod": "tsx scripts/compare-production-contract.ts",
    "inject:local-interceptor": "tsx scripts/inject-local-interceptor.ts",
    "sync:prod-frontend": "tsx scripts/sync-production-frontend.ts",
    "sync:prod-settings": "tsx scripts/sync-production-settings.ts",
    "sync:prod-data": "tsx scripts/sync-production-data.ts",
    "db:generate": "prisma generate",
    "db:push": "prisma db push",
    "db:migrate": "prisma migrate dev",
    "db:migrate:prod": "prisma migrate deploy",
    "db:seed": "node dist/seed.js",
    "db:seed:dev": "tsx src/seed.ts"
  },
  "dependencies": {
    "@prisma/client": "^6.1.0",
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.21.0",
    "express-rate-limit": "^7.4.0",
    "helmet": "^8.0.0",
    "ioredis": "^5.4.1",
    "jsonwebtoken": "^9.0.2",
    "multer": "^1.4.5-lts.1",
    "qrcode": "^1.5.4",
    "socket.io": "^4.8.0",
    "uuid": "^11.0.0",
    "winston": "^3.15.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0",
    "@types/jsonwebtoken": "^9.0.7",
    "@types/multer": "^1.4.12",
    "@types/node": "^22.0.0",
    "@types/qrcode": "^1.5.5",
    "@types/uuid": "^10.0.0",
    "http-proxy-middleware": "^4.1.1",
    "nodemon": "^3.1.0",
    "prisma": "^6.1.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0"
  }
}
