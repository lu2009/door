# ── 部署配置 ──────────────────────────────
# docker compose 已预设大部分变量，这里只覆盖必要的

NODE_ENV=production

# ⚠️ 必须修改：用 openssl rand -hex 32 生成
JWT_SECRET=change-me-to-a-random-string

CORS_ORIGINS=*

# 前端/客户端更新信息
APP_VERSION=1.0.3
WEB_VERSION=2.3.7
APK_UPDATE_URL=https://www.samrtdoor.com.cn/apk/smartdoor-1.0.3.apk
APK_UPDATE_MESSAGE=1.0.3 修复了一些已知问题
WEB_UPDATE_URL=https://www.samrtdoor.com.cn/hotupdate/dist-2.3.7.zip
WEB_UPDATE_MESSAGE=样式更新
FORCE_APK_UPDATE=false
FORCE_WEB_UPDATE=false
